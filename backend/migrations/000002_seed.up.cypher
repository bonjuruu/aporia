MATCH (a:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}), (b:Claim {id: "b522d820-3cbe-5f26-9393-81bbc13a1ff9"}) CREATE (a)-[:ARGUES {id: "e8305390-8603-5661-9596-7bdeaa3d89f7", description: "Camus's affirmation of joy in the face of absurdity", source_text_id: "5f1d12e8-740b-5ab2-892a-d6febcf9fe0f"}]->(b);
MATCH (a:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}), (b:Claim {id: "6fb3c19f-b845-5efb-acf8-1a1fa1cb1751"}) CREATE (a)-[:ARGUES {id: "8dac631f-8822-516b-b651-e3af6f404c65", description: "Sartre's foundational claim of existentialism", source_text_id: "86e6b758-a32e-5300-9517-480691de595f"}]->(b);
MATCH (a:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}), (b:Claim {id: "97d54cb7-7360-58a5-9cf9-65f9e55af382"}) CREATE (a)-[:ARGUES {id: "b8370d71-6790-5645-a24e-488701b6b929", description: "Camus's call for revolt against meaninglessness", source_text_id: "5f1d12e8-740b-5ab2-892a-d6febcf9fe0f"}]->(b);
MATCH (a:Thinker {id: "1337064c-7962-5d42-9f3e-6aab3da87627"}), (b:Claim {id: "c79b1dd0-aaaf-5758-904d-cdc2f70e9cfe"}) CREATE (a)-[:ARGUES {id: "44700923-9847-5677-a569-79233f6ffd01", description: "Schopenhauer's core pessimistic thesis", source_text_id: "e6697acc-2932-5c6d-b58a-9c01fcca9c65"}]->(b);

// Appears_in (Claim/Concept -> Text)
