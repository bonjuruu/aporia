// Thinkers
MERGE (n:Thinker {id: "1337064c-7962-5d42-9f3e-6aab3da87627"}) ON CREATE SET n.name = "Schopenhauer", n.description = "German philosopher known for his pessimistic philosophy and concept of the Will as the fundamental reality", n.notes = "", n.born_year = 1788, n.died_year = 1860, n.tradition = "German Idealism, Pessimism";
MERGE (n:Thinker {id: "31068223-915b-5133-b9b5-a5240693b6b0"}) ON CREATE SET n.name = "Kierkegaard", n.description = "Danish philosopher considered the father of existentialism, focused on individual existence, faith, and despair", n.notes = "", n.born_year = 1813, n.died_year = 1855, n.tradition = "Existentialism, Christian Philosophy";
MERGE (n:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}) ON CREATE SET n.name = "Nietzsche", n.description = "German philosopher who challenged conventional morality and religion, championing the will to power and eternal recurrence", n.notes = "", n.born_year = 1844, n.died_year = 1900, n.tradition = "Existentialism, Nihilism";
MERGE (n:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}) ON CREATE SET n.name = "Camus", n.description = "French-Algerian philosopher and author, central figure in absurdism, explored the conflict between human desire for meaning and the universe's silence", n.notes = "", n.born_year = 1913, n.died_year = 1960, n.tradition = "Absurdism";
MERGE (n:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}) ON CREATE SET n.name = "Sartre", n.description = "French existentialist philosopher who argued that existence precedes essence, emphasizing radical freedom and responsibility", n.notes = "", n.born_year = 1905, n.died_year = 1980, n.tradition = "Existentialism, Phenomenology";
MERGE (n:Thinker {id: "4d175e5a-a39a-5351-b9de-038c1e75dd8c"}) ON CREATE SET n.name = "de Beauvoir", n.description = "French existentialist philosopher and feminist thinker, explored ethics of ambiguity and the construction of gender", n.notes = "", n.born_year = 1908, n.died_year = 1986, n.tradition = "Existentialism, Feminism";

// Concepts
MERGE (n:Concept {id: "54a07857-3a77-57d9-8c0c-6508c6a47495"}) ON CREATE SET n.name = "Will to Power", n.description = "Nietzsche's concept of the fundamental driving force in humans — not merely power over others, but the creative force of self-overcoming", n.notes = "", n.year = 1883;
MERGE (n:Concept {id: "41cc0490-22fd-559b-86e0-0d306c1ce818"}) ON CREATE SET n.name = "Eternal Recurrence", n.description = "The idea that all events in the universe will recur infinitely — used by Nietzsche as a thought experiment for affirming life", n.notes = "", n.year = 1882;
MERGE (n:Concept {id: "ed946b65-4c40-598c-a732-820b598b88f2"}) ON CREATE SET n.name = "The Absurd", n.description = "The conflict between humanity's tendency to seek inherent meaning in life and the universe's silent indifference to such meaning", n.notes = "", n.year = 1942;
MERGE (n:Concept {id: "5dff2ae3-bb01-5d22-ba7d-8af083113f34"}) ON CREATE SET n.name = "Bad Faith", n.description = "Sartre's concept of self-deception where individuals deny their radical freedom by adopting false values or pretending they have no choice", n.notes = "", n.year = 1943;
MERGE (n:Concept {id: "c8cd9ef7-33b4-5d52-b1bb-ea2eabe983dc"}) ON CREATE SET n.name = "The Will", n.description = "Schopenhauer's concept of a blind, purposeless metaphysical force that underlies all of reality and is the source of suffering", n.notes = "", n.year = 1818;
MERGE (n:Concept {id: "9cc5129f-0525-5e74-8917-b88878c1a69a"}) ON CREATE SET n.name = "Despair", n.description = "Kierkegaard's concept of a fundamental sickness of the self, arising from the failure to relate properly to oneself and to the infinite", n.notes = "", n.year = 1849;
MERGE (n:Concept {id: "149b3065-f227-5733-951a-6699494053a0"}) ON CREATE SET n.name = "Nihilism", n.description = "The philosophical position that life lacks objective meaning, purpose, or intrinsic value — a crisis Nietzsche sought to diagnose and overcome", n.notes = "", n.year = 1882;

// Claims
MERGE (n:Claim {id: "cacfa5ab-77c8-577f-8b64-bb9b368f112e"}) ON CREATE SET n.content = "God is dead and we have killed him", n.description = "Nietzsche's proclamation in The Gay Science that modern civilization has rendered God irrelevant, leaving a vacuum of meaning and value", n.notes = "", n.year = 1882;
MERGE (n:Claim {id: "b522d820-3cbe-5f26-9393-81bbc13a1ff9"}) ON CREATE SET n.content = "One must imagine Sisyphus happy", n.description = "Camus's concluding insight that embracing the absurd struggle itself, without hope of resolution, constitutes authentic happiness", n.notes = "", n.year = 1942;
MERGE (n:Claim {id: "6fb3c19f-b845-5efb-acf8-1a1fa1cb1751"}) ON CREATE SET n.content = "Existence precedes essence", n.description = "Sartre's foundational existentialist principle that humans have no predetermined nature — we first exist, then define ourselves through choices", n.notes = "", n.year = 1943;
MERGE (n:Claim {id: "97d54cb7-7360-58a5-9cf9-65f9e55af382"}) ON CREATE SET n.content = "Life is inherently meaningless — but we must revolt against that meaninglessness", n.description = "Camus's argument that acknowledging the absurd does not lead to resignation but to passionate rebellion and living fully", n.notes = "", n.year = 1942;
MERGE (n:Claim {id: "c79b1dd0-aaaf-5758-904d-cdc2f70e9cfe"}) ON CREATE SET n.content = "The will is the source of all suffering", n.description = "Schopenhauer's central thesis that the blind, insatiable striving of the Will traps us in endless cycles of desire and pain", n.notes = "", n.year = 1818;

// Texts
MERGE (n:Text {id: "0d232d11-a55e-5b21-bdc1-d0927fbb1dc5"}) ON CREATE SET n.title = "The Gay Science", n.description = "Nietzsche's joyful exploration of philosophy, art, and truth, containing the first proclamation that God is dead", n.notes = "", n.published_year = 1882;
MERGE (n:Text {id: "9c17a3a7-42dd-5233-ab4c-cdedb6884458"}) ON CREATE SET n.title = "Thus Spoke Zarathustra", n.description = "Nietzsche's philosophical novel introducing the Ubermensch, eternal recurrence, and the will to power through prophetic narrative", n.notes = "", n.published_year = 1883;
MERGE (n:Text {id: "5f1d12e8-740b-5ab2-892a-d6febcf9fe0f"}) ON CREATE SET n.title = "The Myth of Sisyphus", n.description = "Camus's foundational essay on absurdism, arguing that life's lack of meaning demands not suicide but revolt", n.notes = "", n.published_year = 1942;
MERGE (n:Text {id: "86e6b758-a32e-5300-9517-480691de595f"}) ON CREATE SET n.title = "Being and Nothingness", n.description = "Sartre's magnum opus on existentialist ontology, exploring consciousness, freedom, bad faith, and being-for-others", n.notes = "", n.published_year = 1943;
MERGE (n:Text {id: "e6697acc-2932-5c6d-b58a-9c01fcca9c65"}) ON CREATE SET n.title = "The World as Will and Representation", n.description = "Schopenhauer's central work arguing that the world is driven by a blind, purposeless Will and that art and asceticism offer escape from suffering", n.notes = "", n.published_year = 1818;

// Influenced (Thinker -> Thinker)
MATCH (a:Thinker {id: "1337064c-7962-5d42-9f3e-6aab3da87627"}), (b:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}) MERGE (a)-[r:INFLUENCED {id: "88749d04-e9a7-51de-894e-aec349e59fb0"}]->(b) ON CREATE SET r.description = "Schopenhauer's pessimism and concept of the Will profoundly shaped Nietzsche's early philosophy", r.source_text_id = "";
