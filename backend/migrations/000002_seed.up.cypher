// Thinkers
CREATE (n:Thinker {id: "1337064c-7962-5d42-9f3e-6aab3da87627", name: "Schopenhauer", description: "German philosopher known for his pessimistic philosophy and concept of the Will as the fundamental reality", notes: "", born_year: 1788, died_year: 1860});
CREATE (n:Thinker {id: "31068223-915b-5133-b9b5-a5240693b6b0", name: "Kierkegaard", description: "Danish philosopher considered the father of existentialism, focused on individual existence, faith, and despair", notes: "", born_year: 1813, died_year: 1855});
CREATE (n:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15", name: "Nietzsche", description: "German philosopher who challenged conventional morality and religion, championing the will to power and eternal recurrence", notes: "", born_year: 1844, died_year: 1900});
CREATE (n:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645", name: "Camus", description: "French-Algerian philosopher and author, central figure in absurdism, explored the conflict between human desire for meaning and the universe's silence", notes: "", born_year: 1913, died_year: 1960});
CREATE (n:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89", name: "Sartre", description: "French existentialist philosopher who argued that existence precedes essence, emphasizing radical freedom and responsibility", notes: "", born_year: 1905, died_year: 1980});
CREATE (n:Thinker {id: "4d175e5a-a39a-5351-b9de-038c1e75dd8c", name: "de Beauvoir", description: "French existentialist philosopher and feminist thinker, explored ethics of ambiguity and the construction of gender", notes: "", born_year: 1908, died_year: 1986});

// Concepts
CREATE (n:Concept {id: "54a07857-3a77-57d9-8c0c-6508c6a47495", name: "Will to Power", description: "Nietzsche's concept of the fundamental driving force in humans — not merely power over others, but the creative force of self-overcoming", notes: "", year: 1883});
CREATE (n:Concept {id: "41cc0490-22fd-559b-86e0-0d306c1ce818", name: "Eternal Recurrence", description: "The idea that all events in the universe will recur infinitely — used by Nietzsche as a thought experiment for affirming life", notes: "", year: 1882});
CREATE (n:Concept {id: "ed946b65-4c40-598c-a732-820b598b88f2", name: "The Absurd", description: "The conflict between humanity's tendency to seek inherent meaning in life and the universe's silent indifference to such meaning", notes: "", year: 1942});
CREATE (n:Concept {id: "5dff2ae3-bb01-5d22-ba7d-8af083113f34", name: "Bad Faith", description: "Sartre's concept of self-deception where individuals deny their radical freedom by adopting false values or pretending they have no choice", notes: "", year: 1943});
CREATE (n:Concept {id: "c8cd9ef7-33b4-5d52-b1bb-ea2eabe983dc", name: "The Will", description: "Schopenhauer's concept of a blind, purposeless metaphysical force that underlies all of reality and is the source of suffering", notes: "", year: 1818});
CREATE (n:Concept {id: "9cc5129f-0525-5e74-8917-b88878c1a69a", name: "Despair", description: "Kierkegaard's concept of a fundamental sickness of the self, arising from the failure to relate properly to oneself and to the infinite", notes: "", year: 1849});
CREATE (n:Concept {id: "149b3065-f227-5733-951a-6699494053a0", name: "Nihilism", description: "The philosophical position that life lacks objective meaning, purpose, or intrinsic value — a crisis Nietzsche sought to diagnose and overcome", notes: "", year: 1882});

// Claims
CREATE (n:Claim {id: "cacfa5ab-77c8-577f-8b64-bb9b368f112e", content: "God is dead and we have killed him", notes: "", year: 1882});
CREATE (n:Claim {id: "b522d820-3cbe-5f26-9393-81bbc13a1ff9", content: "One must imagine Sisyphus happy", notes: "", year: 1942});
CREATE (n:Claim {id: "6fb3c19f-b845-5efb-acf8-1a1fa1cb1751", content: "Existence precedes essence", notes: "", year: 1943});
CREATE (n:Claim {id: "97d54cb7-7360-58a5-9cf9-65f9e55af382", content: "Life is inherently meaningless — but we must revolt against that meaninglessness", notes: "", year: 1942});
CREATE (n:Claim {id: "c79b1dd0-aaaf-5758-904d-cdc2f70e9cfe", content: "The will is the source of all suffering", notes: "", year: 1818});

// Texts
CREATE (n:Text {id: "0d232d11-a55e-5b21-bdc1-d0927fbb1dc5", title: "The Gay Science", description: "Nietzsche's joyful exploration of philosophy, art, and truth, containing the first proclamation that God is dead", notes: "", published_year: 1882});
CREATE (n:Text {id: "9c17a3a7-42dd-5233-ab4c-cdedb6884458", title: "Thus Spoke Zarathustra", description: "Nietzsche's philosophical novel introducing the Ubermensch, eternal recurrence, and the will to power through prophetic narrative", notes: "", published_year: 1883});
CREATE (n:Text {id: "5f1d12e8-740b-5ab2-892a-d6febcf9fe0f", title: "The Myth of Sisyphus", description: "Camus's foundational essay on absurdism, arguing that life's lack of meaning demands not suicide but revolt", notes: "", published_year: 1942});
CREATE (n:Text {id: "86e6b758-a32e-5300-9517-480691de595f", title: "Being and Nothingness", description: "Sartre's magnum opus on existentialist ontology, exploring consciousness, freedom, bad faith, and being-for-others", notes: "", published_year: 1943});
CREATE (n:Text {id: "e6697acc-2932-5c6d-b58a-9c01fcca9c65", title: "The World as Will and Representation", description: "Schopenhauer's central work arguing that the world is driven by a blind, purposeless Will and that art and asceticism offer escape from suffering", notes: "", published_year: 1818});

// Influenced (Thinker -> Thinker)
MATCH (a:Thinker {id: "1337064c-7962-5d42-9f3e-6aab3da87627"}), (b:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}) CREATE (a)-[:INFLUENCED {id: "88749d04-e9a7-51de-894e-aec349e59fb0", description: "Schopenhauer's pessimism and concept of the Will profoundly shaped Nietzsche's early philosophy", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "31068223-915b-5133-b9b5-a5240693b6b0"}), (b:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}) CREATE (a)-[:INFLUENCED {id: "2fd6f584-7e94-5dad-9e74-226634d80ac3", description: "Kierkegaard's exploration of absurdity and faith influenced Camus's philosophy of the absurd", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}), (b:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}) CREATE (a)-[:INFLUENCED {id: "0e3c84d6-cc4e-527a-aaee-6541f46b88b2", description: "Nietzsche's diagnosis of nihilism and affirmation of life deeply influenced Camus's absurdism", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}), (b:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}) CREATE (a)-[:INFLUENCED {id: "ef89d597-eb40-5a89-ace5-1d4fcdfe1f54", description: "Nietzsche's ideas on freedom, self-creation, and the death of God influenced Sartre's existentialism", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}), (b:Thinker {id: "4d175e5a-a39a-5351-b9de-038c1e75dd8c"}) CREATE (a)-[:INFLUENCED {id: "48537d87-4fb9-5034-a313-92878c9f752a", description: "Sartre's existentialist framework influenced de Beauvoir's philosophical development", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "4d175e5a-a39a-5351-b9de-038c1e75dd8c"}), (b:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}) CREATE (a)-[:INFLUENCED {id: "ce17c999-edd1-59ac-867b-0b01be7de4be", description: "de Beauvoir's ethical philosophy and feminist perspective influenced Sartre's later political thought", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "31068223-915b-5133-b9b5-a5240693b6b0"}), (b:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}) CREATE (a)-[:INFLUENCED {id: "3bd32d4d-fd18-5dba-a437-a09149506550", description: "Kierkegaard's focus on individual existence and choice influenced Sartre's existentialism", source_text_id: ""}]->(b);

// Coined (Thinker -> Concept)
MATCH (a:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}), (b:Concept {id: "54a07857-3a77-57d9-8c0c-6508c6a47495"}) CREATE (a)-[:COINED {id: "97369bbb-3778-551e-80d4-b9a258c08ab6", description: "Nietzsche developed the concept throughout his later works", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}), (b:Concept {id: "41cc0490-22fd-559b-86e0-0d306c1ce818"}) CREATE (a)-[:COINED {id: "171d5969-0a9a-50c2-845a-69fef5c1f8e9", description: "First presented in The Gay Science and central to Zarathustra", source_text_id: "0d232d11-a55e-5b21-bdc1-d0927fbb1dc5"}]->(b);
MATCH (a:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}), (b:Concept {id: "ed946b65-4c40-598c-a732-820b598b88f2"}) CREATE (a)-[:COINED {id: "e451ece7-b821-5e67-8b88-8e656c6e4e2e", description: "Camus articulated the absurd as a philosophical concept in The Myth of Sisyphus", source_text_id: "5f1d12e8-740b-5ab2-892a-d6febcf9fe0f"}]->(b);
MATCH (a:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}), (b:Concept {id: "5dff2ae3-bb01-5d22-ba7d-8af083113f34"}) CREATE (a)-[:COINED {id: "8e4d4b1e-e64f-565d-9e15-6ec6995c2a31", description: "Sartre developed bad faith as a key concept in Being and Nothingness", source_text_id: "86e6b758-a32e-5300-9517-480691de595f"}]->(b);
MATCH (a:Thinker {id: "1337064c-7962-5d42-9f3e-6aab3da87627"}), (b:Concept {id: "c8cd9ef7-33b4-5d52-b1bb-ea2eabe983dc"}) CREATE (a)-[:COINED {id: "361a1956-d350-59cf-b38d-ea89f9241c69", description: "Central concept of The World as Will and Representation", source_text_id: "e6697acc-2932-5c6d-b58a-9c01fcca9c65"}]->(b);
MATCH (a:Thinker {id: "31068223-915b-5133-b9b5-a5240693b6b0"}), (b:Concept {id: "9cc5129f-0525-5e74-8917-b88878c1a69a"}) CREATE (a)-[:COINED {id: "6a1c2d2f-4cac-587d-8d9e-1de465a34e74", description: "Kierkegaard explored despair as a fundamental condition of the self", source_text_id: ""}]->(b);
MATCH (a:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}), (b:Concept {id: "149b3065-f227-5733-951a-6699494053a0"}) CREATE (a)-[:COINED {id: "516fa6df-ba51-5ad2-9da2-75920ae1d79d", description: "Nietzsche diagnosed and named the crisis of nihilism in European culture", source_text_id: ""}]->(b);

