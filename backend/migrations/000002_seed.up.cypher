MATCH (a:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}), (b:Thinker {id: "4d175e5a-a39a-5351-b9de-038c1e75dd8c"}) MERGE (a)-[r:INFLUENCED {id: "48537d87-4fb9-5034-a313-92878c9f752a"}]->(b) ON CREATE SET r.description = "Sartre's existentialist framework influenced de Beauvoir's philosophical development", r.source_text_id = "";
MATCH (a:Thinker {id: "4d175e5a-a39a-5351-b9de-038c1e75dd8c"}), (b:Thinker {id: "38d4e283-d4aa-5ac1-a461-691d107ddc89"}) MERGE (a)-[r:INFLUENCED {id: "ce17c999-edd1-59ac-867b-0b01be7de4be"}]->(b) ON CREATE SET r.description = "de Beauvoir's ethical philosophy and feminist perspective influenced Sartre's later political thought", r.source_text_id = "";
