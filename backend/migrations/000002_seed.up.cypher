// Builds_on / Derives_from / Responds_to
MATCH (a:Concept {id: "54a07857-3a77-57d9-8c0c-6508c6a47495"}), (b:Concept {id: "c8cd9ef7-33b4-5d52-b1bb-ea2eabe983dc"}) CREATE (a)-[:BUILDS_ON {id: "fe28fb88-c8e2-5cdd-85fe-a5dfb5b466ec", description: "Nietzsche transformed Schopenhauer's blind Will into an affirmative, creative force", source_text_id: ""}]->(b);
MATCH (a:Concept {id: "ed946b65-4c40-598c-a732-820b598b88f2"}), (b:Concept {id: "149b3065-f227-5733-951a-6699494053a0"}) CREATE (a)-[:RESPONDS_TO {id: "577aaf6c-b58c-5b7d-92d3-50bde20a0853", description: "Camus's absurdism is a direct response to the crisis of nihilism", source_text_id: ""}]->(b);
MATCH (a:Concept {id: "149b3065-f227-5733-951a-6699494053a0"}), (b:Concept {id: "c8cd9ef7-33b4-5d52-b1bb-ea2eabe983dc"}) CREATE (a)-[:DERIVES_FROM {id: "291530b0-b0c4-52d6-8306-69d634b8f8bc", description: "Schopenhauer's pessimistic metaphysics laid groundwork for nihilistic thought", source_text_id: ""}]->(b);
MATCH (a:Claim {id: "b522d820-3cbe-5f26-9393-81bbc13a1ff9"}), (b:Claim {id: "cacfa5ab-77c8-577f-8b64-bb9b368f112e"}) CREATE (a)-[:RESPONDS_TO {id: "60cc5c78-c407-56aa-94ea-bc3ec9d6a413", description: "Camus's affirmation responds to the void left by the death of God", source_text_id: ""}]->(b);
MATCH (a:Claim {id: "97d54cb7-7360-58a5-9cf9-65f9e55af382"}), (b:Claim {id: "c79b1dd0-aaaf-5758-904d-cdc2f70e9cfe"}) CREATE (a)-[:BUILDS_ON {id: "38c57d36-ed28-5b72-944a-75b0bee8c0b9", description: "Camus builds on Schopenhauer's pessimism but rejects resignation in favor of revolt", source_text_id: ""}]->(b);
MATCH (a:Claim {id: "6fb3c19f-b845-5efb-acf8-1a1fa1cb1751"}), (b:Concept {id: "ed946b65-4c40-598c-a732-820b598b88f2"}) CREATE (a)-[:BUILDS_ON {id: "37b2c52c-744f-5e83-b10c-dd695e214624", description: "Sartre's existentialism extends from the absurdist recognition that there is no pre-given essence", source_text_id: ""}]->(b);
