MATCH (a:Thinker {id: "b9c401cf-dd88-5bbf-8117-e9bb12a5ca15"}), (b:Thinker {id: "7dcaa2bc-7303-5cdb-b585-c144d7030645"}) MERGE (a)-[r:INFLUENCED {id: "0e3c84d6-cc4e-527a-aaee-6541f46b88b2"}]->(b) ON CREATE SET r.description = "Nietzsche's diagnosis of nihilism and affirmation of life deeply influenced Camus's absurdism", r.source_text_id = "";
